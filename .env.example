# QuickDelivery Food Platform - Environment Configuration
# Copy this file to .env and modify values for your environment

# ============================================
# Environment
# ============================================
NODE_ENV=development

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
POSTGRES_DB=quickdelivery
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://postgres:postgres123@postgres:5432/quickdelivery

# ============================================
# Redis Configuration
# ============================================
REDIS_PASSWORD=redis123
# Format: redis://:password@host:port
REDIS_URL=redis://:redis123@redis:6379

# ============================================
# Backend API Configuration
# ============================================
BACKEND_PORT=3000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
CORS_ORIGIN=*

# ============================================
# Frontend API URLs
# ============================================
# Customer App
CUSTOMER_PORT=3001
CUSTOMER_API_URL=http://localhost:3000/api/v1
CUSTOMER_WS_URL=ws://localhost:3000

# Restaurant App
RESTAURANT_PORT=3002
RESTAURANT_API_URL=http://localhost:3000/api/v1
RESTAURANT_WS_URL=ws://localhost:3000

# Admin App
ADMIN_PORT=3003
ADMIN_API_URL=http://localhost:3000/api/v1

# ============================================
# Nginx Configuration
# ============================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ============================================
# Payment Configuration (Stripe/PayPal)
# ============================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# ============================================
# Email Configuration (SendGrid/AWS SES)
# ============================================
# EMAIL_SERVICE=sendgrid
# EMAIL_API_KEY=SG.xxx
# EMAIL_FROM=noreply@quickdelivery.com

# ============================================
# File Storage (AWS S3/MinIO)
# ============================================
# S3_ENDPOINT=s3.amazonaws.com
# S3_BUCKET=quickdelivery-uploads
# S3_ACCESS_KEY=AKIA...
# S3_SECRET_KEY=...
# S3_REGION=us-east-1

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
# LOG_FORMAT=json

# ============================================
# Feature Flags
# ============================================
ENABLE_SWAGGER=true
ENABLE_RATE_LIMITING=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_PUSH_NOTIFICATIONS=false
