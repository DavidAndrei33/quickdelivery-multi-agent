  "test_configuration": {
    "test_root": "/root/clawd/agents/brainmaker/tests",
    "test_pattern": "test_*.py",
    "auto_test_on_fix": true,
    "test_before_deploy": true,
    "test_categories": {
      "unit": {
        "path": "/root/clawd/agents/brainmaker/tests/unit",
        "agent": "qa-tester",
        "pattern": "test_unit_*.py"
      },
      "integration": {
        "path": "/root/clawd/agents/brainmaker/tests/integration",
        "agent": "qa-tester",
        "pattern": "test_integration_*.py"
      },
      "api": {
        "path": "/root/clawd/agents/brainmaker/tests/api",
        "agent": "qa-tester",
        "pattern": "test_api_*.py"
      },
      "e2e": {
        "path": "/root/clawd/agents/brainmaker/tests/e2e",
        "agent": "qa-tester",
        "pattern": "test_e2e_*.py"
      }
    }
  },

  "communication": {
    "shared_directories": {
      "specs": "/workspace/shared/specs",
      "artifacts": "/workspace/shared/artifacts",
      "reviews": "/workspace/shared/reviews",
      "decisions": "/workspace/shared/decisions",
      "tasks": "/workspace/shared/tasks",
      "bugs": "/workspace/shared/bugs"
    },
    "channels": {
      "async": "Shared files (primary)",
      "sync_urgent": "sessions_send",
      "broadcast": "Task board updates"
    }
  },
  
  "workflows": {
    "standard": ["Inbox", "Assigned", "In Progress", "Review", "Done"],
    "bug_fix": ["Reported", "Assigned", "Fixing", "Testing", "Verified", "Closed"],
    "api_development": ["Spec", "Review Spec", "Build", "Test", "Review", "Deploy"]
  },
  
  "retry_policy": {
    "max_attempts": 3,
    "backoff_seconds": [60, 300, 900],
    "escalate_after": 3,
    "auto_retry_on": ["connection_error", "timeout", "transient_failure"]
  },
  
  "quality_gates": {
    "require_review": true,
    "require_tests": true,
    "require_documentation": true,
    "max_review_rounds": 3
  }
}