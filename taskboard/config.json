    "todo": { "label": "To Do", "color": "#74b9ff" },
    "in_progress": { "label": "In Progress", "color": "#fdcb6e" },
    "review": { "label": "Review", "color": "#a29bfe" },
    "done": { "label": "Done", "color": "#00b894" }
  }
